# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build output
frontend/build/
frontend/.cache/

# Environment secrets — NEVER commit these
backend/.env
.env
*.env.local

# Logs
*.log
npm-debug.log*

# Runtime data
backend/data/*.json
!backend/data/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# SSL certs (if local)
backend/certs/*.pem
backend/certs/*.key
