# ── AudienceQ Backend — Environment Variables ────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Public URL of the deployed app (no trailing slash)
# e.g. https://your-app.railway.app  OR  https://yourdomain.com
APP_URL=https://your-app.railway.app

# Default moderator passcode (used for the "default" workspace on first run)
MODERATOR_PASSCODE=admin123

# Anthropic API key — enables AI session summaries (Claude-powered)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Agora (real-time voice/video) ────────────────────────────────────────────
# Get these at https://console.agora.io
AGORA_APP_ID=your_agora_app_id_here
# Optional — enables server-side token auth (recommended for production)
# AGORA_APP_CERTIFICATE=your_agora_app_certificate_here

# Optional: protect /api/workspaces (create new orgs) with an admin key
# If unset, anyone can create a workspace (fine for single-org setups)
# ADMIN_KEY=your-secret-key

# Optional: custom data directory for session JSON files
# Defaults to ./data relative to server.js
# DATA_DIR=/var/data/audienceq
